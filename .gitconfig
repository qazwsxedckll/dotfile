[pull]
	rebase = true
[core]
	editor = vim
	autocrlf = input
[init]
	defaultBranch = main
[fetch]
	prune = true
[push]
	followTags = true
	autoSetupRemote = true
[alias]
	prune-local = "!git fetch -p && for branch in $(git for-each-ref --format '%(refname) %(upstream:track)' refs/heads | awk '$2 == \"[gone]\" {sub(\"refs/heads/\", \"\", $1); print $1}'); do git branch -D $branch; done"
